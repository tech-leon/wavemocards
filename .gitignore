# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
wavemocardsv4/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
.codex/
.claude/

# vercel
.vercel

# migrations (legacy user-migration scripts contain real user PII — keep ignored)
/scripts/*
!/scripts/validate-card-translations.ts
# 003/004 contain real migrated user PII — never track them
supabase/migrations/*
!supabase/migrations/001_initial_schema.sql
!supabase/migrations/002_migration_support.sql
!supabase/migrations/005_add_theme_preference_to_profiles.sql
!supabase/migrations/20260322_add_profiles_locale_preference.sql
!supabase/migrations/20260329*

# typescript
*.tsbuildinfo
next-env.d.ts
